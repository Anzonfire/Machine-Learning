        "import numpy as np\n",
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "from sklearn.linear_model import LogisticRegression\n",
        "from sklearn.metrics import accuracy_score, precision_score, recall_score, f1_score\n",
        "from sklearn.metrics import confusion_matrix, classification_report, roc_curve, roc_auc_score\n",
        "from sklearn.preprocessing import StandardScaler\n",
        "from sklearn.model_selection import train_test_split\n",
        "\n",
        "df2 = pd.read_csv(\"LICI - 10 minute data.csv\")\n",
        "df2['Price_Movement'] = np.where(\n",
        "    df2['close'] > df2['open'], 1, 0\n",
        ")\n",
        "\n",
        "features = ['open', 'high', 'low', 'volume']\n",
        "target = 'Price_Movement'\n",
        "\n",
        "df2 = df2[features + [target]]\n",
        "\n",
        "df2.fillna(df2.median(), inplace=True)\n",
        "\n",
        "X2 = df2[features]\n",
        "y2 = df2[target]\n",
        "\n",
        "\n",
        "scaler2 = StandardScaler()\n",
        "X2_scaled = scaler2.fit_transform(X2)\n",
        "\n",
        "\n",
        "X2_train, X2_test, y2_train, y2_test = train_test_split(\n",
        "    X2_scaled, y2, test_size=0.2, random_state=42\n",
        ")\n",
        "\n",
        "\n",
        "log_model = LogisticRegression()\n",
        "log_model.fit(X2_train, y2_train)\n",
        "\n",
        "\n",
        "y2_pred = log_model.predict(X2_test)\n",
        "\n",
        "\n",
        "print(\"\\nLogistic Regression Results\")\n",
        "print(\"Accuracy:\", accuracy_score(y2_test, y2_pred))\n",
        "print(\"Precision:\", precision_score(y2_test, y2_pred))\n",
        "print(\"Recall:\", recall_score(y2_test, y2_pred))\n",
        "print(\"F1 Score:\", f1_score(y2_test, y2_pred))\n",
        "\n",
        "print(\"\\nConfusion Matrix:\\n\", confusion_matrix(y2_test, y2_pred))\n",
        "print(\"\\nClassification Report:\\n\", classification_report(y2_test, y2_pred))\n",
        "\n",
        "\n",
        "y2_prob = log_model.predict_proba(X2_test)[:,1]\n",
        "fpr, tpr, thresholds = roc_curve(y2_test, y2_prob)\n",
        "\n",
        "plt.plot(fpr, tpr)\n",
        "plt.xlabel(\"False Positive Rate\")\n",
        "plt.ylabel(\"True Positive Rate\")\n",
        "plt.title(\"ROC Curve\")\n",
        "plt.show()\n",
        "\n",
        "print(\"ROC AUC Score:\", roc_auc_score(y2_test, y2_prob))\n",
        "\n",
        "importance = pd.Series(log_model.coef_[0], index=features)\n",
        "importance.plot(kind='bar')\n",
        "plt.title(\"Feature Importance\")\n",
        "plt.show()\n",
        "\n",
        "\n",
        "log_model_tuned = LogisticRegression(C=0.5, penalty='l2')\n",
        "log_model_tuned.fit(X2_train, y2_train)\n",
        "\n",
        "y2_tuned_pred = log_model_tuned.predict(X2_test)\n",
        "\n",
        "print(\"\\nTuned Accuracy:\", accuracy_score(y2_test, y2_tuned_pred))"
      ]
